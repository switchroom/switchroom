#!/bin/bash
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
export PATH="$HOME/.bun/bin:$PATH"
export CLAUDE_CONFIG_DIR="{{agentDir}}/.claude"
export TELEGRAM_STATE_DIR="{{agentDir}}/telegram"
# CLERK_AGENT_NAME is the canonical "which agent am I" identifier the
# telegram-plugin reads to detect self-restart commands. We can't rely on
# basename(process.cwd()) inside the plugin because Claude Code spawns
# MCP servers with cwd = $HOME regardless of the parent's cwd.
export CLERK_AGENT_NAME="{{name}}"
{{#if hindsightEnabled}}
# Hindsight memory plugin (vendored at .claude/plugins/hindsight-memory/).
# Reads env vars at hook startup; settings.json autoMemoryEnabled: false
# disables Claude Code's built-in file-based auto-memory so we don't run
# two memory systems against each other.
export HINDSIGHT_API_URL="{{hindsightApiBaseUrl}}"
export HINDSIGHT_BANK_ID="{{hindsightBankId}}"
export HINDSIGHT_AUTO_RECALL=true
export HINDSIGHT_AUTO_RETAIN=true
export HINDSIGHT_AGENT_NAME="{{name}}"
{{#if hindsightApiToken}}export HINDSIGHT_API_TOKEN="{{hindsightApiToken}}"
{{/if}}
{{/if}}
{{#if userEnv}}
# User-declared env vars from clerk.yaml (agent + defaults merged).
# These take precedence over the vars above because they appear later.
{{#each userEnv}}export {{@key}}="{{this}}"
{{/each}}
{{/if}}
cd "{{agentDir}}"
{{#if useClerkPlugin}}exec claude --dangerously-load-development-channels server:clerk-telegram{{#if hindsightEnabled}} --plugin-dir "{{agentDir}}/.claude/plugins/hindsight-memory"{{/if}}{{#if model}} --model {{model}}{{/if}}{{#if systemPromptAppendShellQuoted}} --append-system-prompt {{{systemPromptAppendShellQuoted}}}{{/if}}{{#if dangerousMode}} --dangerously-skip-permissions{{/if}}
{{else}}exec claude --channels plugin:telegram@claude-plugins-official{{#if hindsightEnabled}} --plugin-dir "{{agentDir}}/.claude/plugins/hindsight-memory"{{/if}}{{#if model}} --model {{model}}{{/if}}{{#if systemPromptAppendShellQuoted}} --append-system-prompt {{{systemPromptAppendShellQuoted}}}{{/if}}{{#if dangerousMode}} --dangerously-skip-permissions{{/if}}
{{/if}}

#!/usr/bin/expect -f
#
# Switchroom autoaccept: automatically respond to Claude Code FIRST-RUN
# TUI prompts that appear when launching a fresh agent (theme picker,
# provider picker, MCP trust dialog, dev-channels acknowledgement).
#
# IMPORTANT: this script deliberately does NOT auto-accept per-tool
# permission prompts (the "Yes and don't ask again" dialog). Those
# prompts are the security boundary that lets Ken approve or deny
# individual tool calls from Telegram via the inline-button flow in
# server.ts (pendingPermissions + notifications/claude/channel/
# permission_request). If you auto-accept them here, the approval UX
# is silently bypassed. Leave that prompt alone so the plugin's
# permission-request notification can fire.
#
# TIOCSTI is disabled by default on Ubuntu 24.04+ (kernel security), so
# we use expect instead of the old Python PTY approach. expect is
# ubiquitous and reliable on every Linux distro.
#
# The bounded regex `.{1,30}` is important: Claude's TUI inserts
# `\033[1C` (cursor right) escape sequences between words in prompt
# text, so naive literal matching fails.
#
# Usage: autoaccept.exp <start-script>

set timeout -1
set start_sh [lindex $argv 0]
spawn /bin/bash -l $start_sh

expect {
    -re {Yes.{0,10}I.{0,5}accept} {
        # Bypass permissions warning (dev channels acknowledgement,
        # shown once per machine). Not a per-tool gate.
        sleep 0.5
        send "\033\[B\r"
        exp_continue
    }
    -re {Use this and all future MCP servers} {
        # MCP server trust prompt
        sleep 0.5
        send "\r"
        exp_continue
    }
    -re {Choose.{1,30}text.{1,30}style} {
        # First-run theme selection — pick option 1 (Auto)
        sleep 0.5
        send "\r"
        exp_continue
    }
    -re {Anthropic.{1,80}Bedrock} {
        # First-run API provider selection — pick Anthropic (option 1)
        sleep 0.5
        send "\r"
        exp_continue
    }
    -re {Enter.{1,30}confirm} {
        # Generic "Enter to confirm" prompt (dev channels, trust dialog)
        sleep 0.8
        send "\r"
        exp_continue
    }
    eof
}

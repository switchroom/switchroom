{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node", "bun"]
  },
  "include": ["src/**/*.ts", "bin/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}

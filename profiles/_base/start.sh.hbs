#!/bin/bash
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
export PATH="$HOME/.bun/bin:$PATH"
export CLAUDE_CONFIG_DIR="{{agentDir}}/.claude"
export TELEGRAM_STATE_DIR="{{agentDir}}/telegram"
# CLERK_AGENT_NAME is the canonical "which agent am I" identifier the
# telegram-plugin reads to detect self-restart commands. We can't rely on
# basename(process.cwd()) inside the plugin because Claude Code spawns
# MCP servers with cwd = $HOME regardless of the parent's cwd.
export CLERK_AGENT_NAME="{{name}}"
{{#if hindsightEnabled}}
# Hindsight memory plugin (vendored at .claude/plugins/hindsight-memory/).
# Reads env vars at hook startup; settings.json autoMemoryEnabled: false
# disables Claude Code's built-in file-based auto-memory so we don't run
# two memory systems against each other.
# Values are POSIX-single-quoted in scaffold.ts for shell safety.
export HINDSIGHT_API_URL={{{hindsightApiBaseUrlQ}}}
export HINDSIGHT_BANK_ID={{{hindsightBankIdQ}}}
export HINDSIGHT_AUTO_RECALL=true
export HINDSIGHT_AUTO_RETAIN=true
export HINDSIGHT_AGENT_NAME="{{name}}"
{{/if}}
{{#if userEnvQuoted}}
# User-declared env vars from clerk.yaml (agent + defaults merged).
# Values are POSIX-single-quoted in scaffold.ts so arbitrary bytes
# (including &, $, backtick, newline, embedded quotes) survive shell
# parsing. Triple braces skip Handlebars HTML-escape of the quoted form.
{{#each userEnvQuoted}}export {{@key}}={{{this}}}
{{/each}}
{{/if}}
cd "{{agentDir}}"

# Fresh session every start — avoids context-window blowout after heavy
# autonomous work. Hindsight auto-recall surfaces relevant past memories
# on every user message via the UserPromptSubmit hook.
CONTINUE_FLAG=""

{{#if handoffEnabled}}
# --- Session handoff briefing ---
# On a normal shutdown the Stop hook writes .handoff.md (compact
# summary of the prior session) into the agent dir. Here we merge that
# briefing into --append-system-prompt so the fresh session wakes up
# already knowing what was going on. If the prior session crashed
# without firing the Stop hook, we fall back to a synchronous
# summarization capped at 2s — if that doesn't finish, skip gracefully
# and rely on Hindsight's per-turn auto-recall.
HANDOFF_FILE="{{agentDir}}/.handoff.md"
if [ ! -s "$HANDOFF_FILE" ]; then
  _LATEST_JSONL=$(ls -t "$CLAUDE_CONFIG_DIR/projects/"*/*.jsonl 2>/dev/null | head -1)
  if [ -n "$_LATEST_JSONL" ]; then
    _LAST_MOD=$(stat -c %Y "$_LATEST_JSONL" 2>/dev/null || echo 0)
    _NOW=$(date +%s)
    if [ $((_NOW - _LAST_MOD)) -lt 600 ]; then
      timeout 2 clerk handoff "{{name}}" 2>/dev/null || true
    fi
  fi
fi
# Telegram plugin reads this to decide whether to prepend the visible
# "↩️ Picked up where we left off — <topic>" line on the first reply.
export CLERK_HANDOFF_SHOW_LINE={{#if handoffShowLine}}true{{else}}false{{/if}}
APPEND_PROMPT={{#if systemPromptAppendShellQuoted}}{{{systemPromptAppendShellQuoted}}}{{else}}""{{/if}}
if [ -s "$HANDOFF_FILE" ]; then
  _HANDOFF_CONTENT=$(cat "$HANDOFF_FILE")
  if [ -n "$APPEND_PROMPT" ]; then
    APPEND_PROMPT="$APPEND_PROMPT

---

$_HANDOFF_CONTENT"
  else
    APPEND_PROMPT="$_HANDOFF_CONTENT"
  fi
fi
{{else}}
APPEND_PROMPT={{#if systemPromptAppendShellQuoted}}{{{systemPromptAppendShellQuoted}}}{{else}}""{{/if}}
{{/if}}

{{#if useClerkPlugin}}
if [ -n "$APPEND_PROMPT" ]; then
  exec claude $CONTINUE_FLAG --dangerously-load-development-channels server:clerk-telegram{{#if hindsightEnabled}} --plugin-dir "{{agentDir}}/.claude/plugins/hindsight-memory"{{/if}}{{#if modelQ}} --model {{{modelQ}}}{{/if}} --append-system-prompt "$APPEND_PROMPT"{{#if dangerousMode}} --dangerously-skip-permissions{{/if}}{{#if extraCliArgs}}{{{extraCliArgs}}}{{/if}}
else
  exec claude $CONTINUE_FLAG --dangerously-load-development-channels server:clerk-telegram{{#if hindsightEnabled}} --plugin-dir "{{agentDir}}/.claude/plugins/hindsight-memory"{{/if}}{{#if modelQ}} --model {{{modelQ}}}{{/if}}{{#if dangerousMode}} --dangerously-skip-permissions{{/if}}{{#if extraCliArgs}}{{{extraCliArgs}}}{{/if}}
fi
{{else}}
if [ -n "$APPEND_PROMPT" ]; then
  exec claude $CONTINUE_FLAG --channels plugin:telegram@claude-plugins-official{{#if hindsightEnabled}} --plugin-dir "{{agentDir}}/.claude/plugins/hindsight-memory"{{/if}}{{#if modelQ}} --model {{{modelQ}}}{{/if}} --append-system-prompt "$APPEND_PROMPT"{{#if dangerousMode}} --dangerously-skip-permissions{{/if}}{{#if extraCliArgs}}{{{extraCliArgs}}}{{/if}}
else
  exec claude $CONTINUE_FLAG --channels plugin:telegram@claude-plugins-official{{#if hindsightEnabled}} --plugin-dir "{{agentDir}}/.claude/plugins/hindsight-memory"{{/if}}{{#if modelQ}} --model {{{modelQ}}}{{/if}}{{#if dangerousMode}} --dangerously-skip-permissions{{/if}}{{#if extraCliArgs}}{{{extraCliArgs}}}{{/if}}
fi
{{/if}}

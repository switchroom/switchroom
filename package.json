{
  "name": "switchroom-ai",
  "version": "0.2.0",
  "description": "Run Claude Code 24/7 on your Claude Pro/Max subscription over Telegram. Open-source alternative to OpenClaw and NanoClaw — no API keys, no Docker.",
  "type": "module",
  "bin": {
    "switchroom": "./dist/cli/switchroom.js"
  },
  "main": "./dist/cli/switchroom.js",
  "files": [
    "dist",
    "profiles",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun bin/switchroom.ts",
    "build": "node scripts/build.mjs",
    "test": "vitest run && bun test telegram-plugin/tests/history.test.ts telegram-plugin/tests/ipc-server-client.test.ts telegram-plugin/tests/gateway-bridge.test.ts telegram-plugin/tests/gateway-startup-mutex.test.ts telegram-plugin/tests/gateway-clean-shutdown-marker.test.ts",
    "test:vitest": "vitest run",
    "test:bun": "bun test telegram-plugin/tests/history.test.ts telegram-plugin/tests/ipc-server-client.test.ts telegram-plugin/tests/gateway-bridge.test.ts telegram-plugin/tests/gateway-startup-mutex.test.ts telegram-plugin/tests/gateway-clean-shutdown-marker.test.ts",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run lint && npm test"
  },
  "dependencies": {
    "@opentelemetry/api-logs": "^0.215.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-logs": "^0.215.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "chalk": "^5.4.0",
    "commander": "^13.1.0",
    "handlebars": "^4.7.8",
    "posthog-node": "^5.29.2",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "3.2.4",
    "buildkite-test-collector": "^1.9.5",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mekenthompson/switchroom.git"
  },
  "homepage": "https://github.com/mekenthompson/switchroom#readme",
  "bugs": {
    "url": "https://github.com/mekenthompson/switchroom/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "workspaces": [
    "telegram-plugin"
  ],
  "keywords": [
    "claude-code",
    "claude-pro",
    "claude-max",
    "claude-subscription",
    "anthropic",
    "openclaw-alternative",
    "nanoclaw-alternative",
    "opencode-alternative",
    "multi-agent",
    "telegram",
    "telegram-bot",
    "orchestrator",
    "ai-agent",
    "self-hosted",
    "oauth",
    "24-7"
  ],
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.1"
  }
}

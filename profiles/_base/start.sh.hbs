#!/bin/bash
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
export PATH="$HOME/.bun/bin:$PATH"
export CLAUDE_CONFIG_DIR="{{agentDir}}/.claude"
export TELEGRAM_STATE_DIR="{{agentDir}}/telegram"
# CLERK_AGENT_NAME is the canonical "which agent am I" identifier the
# telegram-plugin reads to detect self-restart commands. We can't rely on
# basename(process.cwd()) inside the plugin because Claude Code spawns
# MCP servers with cwd = $HOME regardless of the parent's cwd.
export CLERK_AGENT_NAME="{{name}}"
{{#if hindsightEnabled}}
# Hindsight memory plugin (vendored at .claude/plugins/hindsight-memory/).
# Reads env vars at hook startup; settings.json autoMemoryEnabled: false
# disables Claude Code's built-in file-based auto-memory so we don't run
# two memory systems against each other.
# Values are POSIX-single-quoted in scaffold.ts for shell safety.
export HINDSIGHT_API_URL={{{hindsightApiBaseUrlQ}}}
export HINDSIGHT_BANK_ID={{{hindsightBankIdQ}}}
export HINDSIGHT_AUTO_RECALL=true
export HINDSIGHT_AUTO_RETAIN=true
export HINDSIGHT_AGENT_NAME="{{name}}"
{{/if}}
{{#if userEnvQuoted}}
# User-declared env vars from clerk.yaml (agent + defaults merged).
# Values are POSIX-single-quoted in scaffold.ts so arbitrary bytes
# (including &, $, backtick, newline, embedded quotes) survive shell
# parsing. Triple braces skip Handlebars HTML-escape of the quoted form.
{{#each userEnvQuoted}}export {{@key}}={{{this}}}
{{/each}}
{{/if}}
cd "{{agentDir}}"

# --- Session freshness check ---
# Decide whether to resume the previous session (--continue) or start
# fresh based on idle time and turn count. A fresh session gets a clean
# context window; Hindsight auto-recall brings back relevant memories.
CONTINUE_FLAG="--continue"
{{#if sessionMaxIdleSecs}}
_SESSION_DIR="$CLAUDE_CONFIG_DIR/sessions"
if [ -d "$_SESSION_DIR" ]; then
  _LATEST=$(ls -t "$_SESSION_DIR/"*.jsonl 2>/dev/null | head -1)
  if [ -n "$_LATEST" ]; then
    _LAST_MOD=$(stat -c %Y "$_LATEST" 2>/dev/null || echo 0)
    _NOW=$(date +%s)
    _IDLE=$((_NOW - _LAST_MOD))
    if [ "$_IDLE" -gt {{sessionMaxIdleSecs}} ]; then
      CONTINUE_FLAG=""
    fi
  fi
fi
{{/if}}
{{#if sessionMaxTurns}}
if [ -n "$CONTINUE_FLAG" ]; then
  _SESSION_DIR="$CLAUDE_CONFIG_DIR/sessions"
  if [ -d "$_SESSION_DIR" ]; then
    _LATEST=$(ls -t "$_SESSION_DIR/"*.jsonl 2>/dev/null | head -1)
    if [ -n "$_LATEST" ]; then
      _TURNS=$(grep -c '"type":"user"' "$_LATEST" 2>/dev/null || echo 0)
      if [ "$_TURNS" -gt {{sessionMaxTurns}} ]; then
        CONTINUE_FLAG=""
      fi
    fi
  fi
fi
{{/if}}

{{#if useClerkPlugin}}exec claude $CONTINUE_FLAG --dangerously-load-development-channels server:clerk-telegram{{#if hindsightEnabled}} --plugin-dir "{{agentDir}}/.claude/plugins/hindsight-memory"{{/if}}{{#if modelQ}} --model {{{modelQ}}}{{/if}}{{#if systemPromptAppendShellQuoted}} --append-system-prompt {{{systemPromptAppendShellQuoted}}}{{/if}}{{#if dangerousMode}} --dangerously-skip-permissions{{/if}}{{#if extraCliArgs}}{{{extraCliArgs}}}{{/if}}
{{else}}exec claude $CONTINUE_FLAG --channels plugin:telegram@claude-plugins-official{{#if hindsightEnabled}} --plugin-dir "{{agentDir}}/.claude/plugins/hindsight-memory"{{/if}}{{#if modelQ}} --model {{{modelQ}}}{{/if}}{{#if systemPromptAppendShellQuoted}} --append-system-prompt {{{systemPromptAppendShellQuoted}}}{{/if}}{{#if dangerousMode}} --dangerously-skip-permissions{{/if}}{{#if extraCliArgs}}{{{extraCliArgs}}}{{/if}}
{{/if}}
